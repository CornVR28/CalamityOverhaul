QuickHack: {
	SynapseBurn: {
		DisplayName: 突触焚毁
		Description: 超载目标神经突触，造成持续热伤害
	}

	ShortCircuit: {
		DisplayName: 短路
		Description: 释放电磁脉冲造成即时伤害并短暂麻痹
	}

	Cyberpsychosis: {
		DisplayName: 赛博精神病
		Description: 使目标陷入癫狂，攻击周围一切单位
	}

	SystemReset: {
		DisplayName: 系统重置
		Description: 强制重启目标系统，使其完全瘫痪
	}

	OpticOverload: {
		DisplayName: 视觉过载
		Description: 致盲目标，使其无法感知周围环境
	}

	MemoryWipe: {
		DisplayName: 记忆清除
		Description: 清除目标的敌意数据，重置仇恨列表
	}

	Contagion: {
		DisplayName: 蔓延
		Description: 植入自我复制的恶意程序，向周围目标扩散
	}

	TileDetonate: {
		DisplayName: 物块爆破
		Description: 瓦解结构完整性，触发区域性爆炸
	}

	TilePhase: {
		DisplayName: 虚化协议
		Description: 篡改物块物理属性，使其在一段时间内变为虚体
	}

	TileMagPull: {
		DisplayName: 磁力牵引
		Description: 生成磁场，将附近掉落物吸引向你
	}

	MachineShortCircuit: {
		DisplayName: 机械短路
		Description: 清空目标机械电能，释放电弧伤害附近实体
	}

	TurretHijack: {
		DisplayName: 炮塔劫持
		Description: 篡改IFF识别模块，临时翻转炮塔敌我判定
	}

	FalseMemory: {
		DisplayName: 记忆修改
		Description: 植入虚假记忆，令其短暂中断追杀行为或抑制其杀人规律
	}

	SelfDismember: {
		DisplayName: 自我肢解
		Description: 令其肢解自身的灵异
	}

	SystemHalt: {
		DisplayName: 死机
		Description: 令目标短暂陷入沉寂并停止一切活动
	}
}

