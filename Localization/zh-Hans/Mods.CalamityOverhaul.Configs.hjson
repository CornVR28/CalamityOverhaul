CWRServerConfig: {
	DisplayName: 内容设置

	WeaponOverhaul: {
		Label: 武器大修
		Tooltip:
			'''
			启用后会修改大部分的武器
			[c/FF0000:如果您希望可以最优化的体验灾厄大修的内容，请开启它！]
			'''
	}

	ScreenVibration: {
		Label: 武器特殊攻击屏幕振动效果
		Tooltip: 如果开启，在进行一些攻击时会让屏幕发生振动，这或许可以让打击感更加强烈
	}

	MurasamaSpaceFragmentationBool: {
		Label: 鬼妖村正终结技碎屏效果
		Tooltip:
			'''
			默认开启，鬼妖村正进行终结技时会制造屏幕破碎的特效用于增强打击感
			如果关闭便会禁用这些特效，可以根据您的喜好设置
			'''
	}

	HalibutDomainConciseDisplay: {
		Label: 比目鱼海洋领域简约显示
		Tooltip: 默认关闭，开启后会屏蔽掉领域内大多数的视觉效果
	}

	Headers: {
		CWRSystem: 大修系统设置
		CWRWeapon: 大修武器设置
		CWRUI: 大修UI设置
		CWRWorldGen: 大修结构设置
	}

	LensEasing: {
		Label: 镜头缓动
		Tooltip: 启用后，长距离快速位移会让镜头具有缓动，这避免了移动过快所带来的违和感
	}

	WeaponHandheldDisplay: {
		Label: 武器手持显示
		Tooltip:
			'''
			开启后，多数武器会拥有手持动画和特殊使用动作
			这个效果的优先级非常高，会覆盖掉绝大多数第三方模组的手持动画
			默认开启，并且出于视觉体验考虑，作者不建议关闭
			如果您是在游戏中途更改该配置，则一些效果需要重新加载模组后才能改变
			'''
	}

	BowArrowDraw: {
		Label: 绘制弓弦箭矢
		Tooltip:
			'''
			玩家使用弓类进行攻击时，会实时绘制出对应的箭矢动画
			默认开启，可以根据个人喜好进行设置
			'''
	}

	EnableCasingsEntity: {
		Label: 启用弹壳实体
		Tooltip: 如果觉得滚动一地的弹壳很碍眼，关掉这个选项将是一个好主意
	}

	WeaponLazyRotationAngle: {
		Label: 武器惰性旋转角更新
		Tooltip:
			'''
			如果启用，会让手持类武器的使用动画更加接近原版，
			使用的朝向将只在开火时改变一次
			'''
	}

	BiologyOverhaul: {
		Label: 生物大修[c/06e33f:(实验性)]
		Tooltip:
			'''
			[c/c20909:未完成]
			默认开启，会修改一些生物的AI行为，比如死亡模组下的BossAI
			这可能会让游戏的挑战性剧增，可以根据个人喜好选择是否关闭
			'''
	}

	EnableSwordLight: {
		Label: 启用刀光
		Tooltip:
			'''
			默认开启，许多刀剑类武器将会拥有炫彩亮丽的刀光
			在绝大多数情况下，这会让游戏变得更酷
			'''
	}

	MuraUIStyleType: {
		Label: 鬼妖村正UI样式选择
		Tooltip:
			'''
			样式1:精致-悬浮于头顶
			样式2:精致-紧凑
			样式3:经典-悬浮于头顶
			样式4:经典-紧凑
			样式5:隐蔽
			'''
	}

	MuraPosStyleType: {
		Label: 鬼妖村正UI位置选择
		Tooltip:
			'''
			预设1:右下
			预设2:左下
			预设3:居高
			'''
	}

	ShowReloadingProgressUI: {
		Label: 显示装弹进度
		Tooltip: 开启后会让弹药装填的进度被显示出来
	}

	QuestLog: {
		Label: 任务书指引
		Tooltip:
			'''
			启用后，在游戏进程中将会有任务书指引玩家
			可以使用任务书物品、背包中的启动UI，或者快捷键打开任务书界面查看当前任务
			默认开启，禁用后将不会有任何任务指引
			'''
	}

	DialogueBox_Scale_Value: {
		Label: 对话框缩放
		Tooltip: 调整对话框的整体大小
	}

	GenWindGrivenGenerator: {
		Label: 生成风力发电机
		Tooltip: 在世界中放置风力驱动的发电机结构
	}

	GenWGGCollector: {
		Label: 生成拾荒者
		Tooltip: 在世界各处随机生成拾荒者敌对建筑，这个设置只会在传奇世界中生效
	}

	GenJunkmanBase: {
		Label: 生成拾荒者基地
		Tooltip: 在荒原或地下生成拾荒者的据点基地
	}

	GenRocketHut: {
		Label: 生成火箭小屋
		Tooltip: 生成一个含有火箭零件或科技遗物的神秘小屋
	}

	GenSylvanOutpost: {
		Label: 生成森之哨站
		Tooltip: 在森林深处生成木制的精灵或森林守卫哨站
	}

	SignalTowerDecryptionAutoPlay: {
		Label: 信号塔破译傻瓜模式
		Tooltip:
			'''
			开启后，信号塔解密的破译小游戏将自动演示正确解答
			游戏会在新一轮生成后自动按正确路径点击字节块
			既保证演出完整性，也解决玩家卡关的困扰
			默认关闭，保留原有交互挑战
			'''
	}
}
