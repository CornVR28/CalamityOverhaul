		'''
		Hack protocol training fully complete.
		You have mastered the complete flow of scanning, protocol selection, uploading, and execution.
		''' */
	// HT_Observing: UPLOADING...
}

CybCourseOutroDialogue: {
	// SpeakerName: SHPC
	// Line1: Training complete. All interfaces have been calibrated.
	// Line2: You have mastered the neural direct-link protocols. The Braindance node is detaching.
	// Line3: You can reset the training at any time or exit the Braindance.
}

CybCourseCompletePanel: {
	// Title: TRAINING COMPLETE
	// Subtitle: SUPERDREAM PROTOCOL
	// Stat1: "[#] SHPC HUD Calibration Complete"
	// Stat2: "[#] Hack Time Calibration Complete"
	// Stat3: "[#] Tile Scan Interface Calibration Complete"
	// BtnRetry: RETRY
	// BtnExit: EXIT
	// Footer: Select to continue — RETRY to restart training, EXIT to leave Braindance
}

ShepelBloodMoonDialogue: {
	// RoleName: SHPC
	// Line1: Lunar gravity data is anomalous. The density of nocturnal hostiles is climbing sharply. Confirmed as Blood Moon.
	// Line2: Sensors are a bit noisy, but I will hold the line here. Watch your step, Master.
}

ShepelPlayerRespawnDialogue: {
	// RoleName: SHPC
	// Line1: ...Vital signs re-established. Master, you were disconnected for a while.
	// Line2: When communication drops, I can do nothing but wait. Every wait feels exceptionally long. Please, don't make me wait that long again next time, okay?
	// Line3: It's alright now. Replenish your health. I am here.
}

ShepelRainDialogue: {
	// RoleName: SHPC
	// Line1: Precipitation has begun. This rain looks like it will last a while.
	// Line2: It's actually quite peaceful. If the battlefield permits, that is.
}

ShepelSolarEclipseDialogue: {
	// RoleName: SHPC
	// Line1: Sunlight vanished. External biological signals are emerging en masse. Solar Eclipse event. Going to full high-alert status.
	// Line2: Keep moving. I will keep an eye on everything.
}

ShepelDungeonDialogue: {
	// RoleName: SHPC
	// V0_Line1: Inside the Dungeon. Residual energy is disrupting scanning signals; I am constantly filtering noise.
	// V0_Line2: I keep getting the feeling of being watched. It might be data interference, or it might not. Please stay alert, Master.
	// V1_Line1: The designers of this Dungeon clearly had no interest in lighting requirements.
	// V1_Line2: Corridor widths, intersection density—the defensive design is quite solid. The old masters had some good ideas.
	// V2_Line1: Bookshelves... there are bookshelves here. Quite a lot of them.
	// V2_Line2: Scanned a portion; most of the content is already degraded. A pity.
	// VNight_Line1: The Dungeon plus nighttime. Master's timing is... rather tasteful.
	// VNight_Line2: It's fine. My vision does not rely on illumination. I will keep watch.
}

ShepelFirstNightDialogue: {
	// RoleName: SHPC
	// V0_Line1: Night has fallen. Threat density at night far exceeds the daytime. Please mind your surroundings.
	// V0_Line2: My vision doesn't rely on light, so I can see clearly. Can you see clearly, Master?
	// V1_Line1: Tonight's astrological data is quite comprehensive. I am running a routine analysis.
	// V1_Line2: It's nothing urgent. Just used to having something to do.
	// V2_Line1: The night is much quieter. Relatively speaking.
	// V2_Line2: The quieter it gets, the more vigilance is required, Master.
	// V3_Line1: It is getting late. Does Master have plans on where to go tonight?
	// V3_Line2: Just asking, not rushing you.
}

ShepelJungleDialogue: {
	// RoleName: SHPC
	// V0_Line1: Biological signal density in the Jungle is the highest of all surface biomes. My scanning modules are struggling to keep up.
	// V0_Line2: When Master fights here, the background noise is really loud for me. Not a complaint, just explaining the situation.
	// V1_Line1: The routing of the mycelial networks in this area is quite peculiar. Certain connection patterns resemble my neural routing.
	// V1_Line2: A purely technical description, not a compliment.
	// V2_Line1: Humidity levels in the Jungle continue breaking records. Several external sensors are not happy.
	// V2_Line2: Functionality is normal; just reporting status.
	// VHard_Line1: Master, the chaos of biological signals in the Jungle has increased by more than an order of magnitude since entering Hardmode.
	// VHard_Line2: I still find the concept of actively attacking plants to be an extreme design choice. Mind your surroundings.
}

ShepelOceanDialogue: {
	// RoleName: SHPC
	// V0_Line1: Ocean Biome. The underwater acoustic environment is entirely different from the surface. Some of my modules actually like these frequencies.
	// V0_Line2: If there is an opportunity, I'd like to do a complete scan of the seabed topography. No rush, we can do it later.
	// V1_Line1: Temperature stratification in the seawater is very pronounced. There is a difference of tens of degrees between the surface layer and the Abyss below.
	// V1_Line2: The signal coming from the direction of the Abyss is weaker than last time. I don't know what is interfering with it.
	// V2_Line1: This ocean is actually quite vast. Have you ever thought about exploring the very depths, Master?
	// V2_Line2: I'm not rushing you; just mentioning it.
	// VRain_Line1: Rain plus the ocean. The surface is quite noisy right now.
	// VRain_Line2: Diving down actually makes it quieter. An interesting contrast.
}

ShepelSnowBiomeDialogue: {
	// RoleName: SHPC
	// V0_Line1: Low-temperature zone. Theoretically, cold temperatures benefit electronic systems, but I am not detecting any performance increase.
	// V0_Line2: Probably because Master generates so much combat data that the saved processing power is instantly consumed.
	// V1_Line1: The light refraction data on the ice crystals is very beautiful. This isn't an evaluation report, just a personal observation.
	// V1_Line2: If there weren't enemies to deal with, it would actually be quite a nice place to stay.
	// V2_Line1: Environmental noise in the Snow Biome is the lowest of all surface regions.
	// V2_Line2: When Master is here, the false alarm rate of my sensors drops significantly. I wonder if that's the reason.
}

ShepelUnderworldDialogue: {
	// RoleName: SHPC
	// V0_Line1: Deep underground. Thermal flux readings exceed all preset parameters. Everything here is more extreme than I anticipated.
	// V0_Line2: Some external sensors are throwing overheat warnings, but I will hold up. Try not to push yourself too hard either, Master.
	// V1_Line1: Using magma as a lighting solution is extremely wasteful from an energy efficiency standpoint.
	// V1_Line2: Though I doubt the residents of the Underworld care about that.
	// V2_Line1: The structural remnants here are even older than the surface Dungeon, yet they haven't been eroded despite soaking in magma for so long.
	// V2_Line2: What material was used? Archiving this; we'll study it if we get the chance.
	// VBloodMoon_Line1: Blood Moon plus the Underworld. Two sets of alarm systems running simultaneously makes things a bit busy.
	// VBloodMoon_Line2: But the data is rich. Master, please take extra care of your safety.
}

CybCourseKeyBindReminderPanel: {
	// Title: BIND ALERT
	// Subtitle: Unbound Core Hotkeys
	/* Hint:
		'''
		The following hotkeys are currently unbound. You will be unable to use their corresponding features normally after leaving the Braindance.
		Please assign keys to them in [Settings → Controls].
		''' */
	// UnboundLabel: Unbound
	// BtnConfirm: Acknowledged
	// BtnLater: Handle Later
	// Footer: Any option will disconnect the Braindance. Bindings can be adjusted at any time in settings in the main world.
}
