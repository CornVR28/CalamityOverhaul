	// DecryptionPanelSubtitleLocked: 协议封锁·需要人工破译
	// DecryptionPanelSubtitleBreaching: 破译进行中
	// DecryptionPanelSubtitleDataFlood: 数据洪流注入
	// DecryptionPanelSubtitleMessage: 解码信号回放
	// DecryptionPanelTerminalId: TERM-ID ▸ {0}
	// DecryptionPanelCoordinate: ΔPOS ▸ {0}, {1}
	// DecryptionPanelSignalLock: 信号锁定强度
	// DecryptionPanelSignalLockValue: "{0}%"
	// DecryptionPanelFooter: "[ESC] 断开连接    [左键] 交互    [?] 帮助"
	// DecryptionPanelHintLocked: 信号层被加密栅格封闭。按 [空格] 或点击 [启动破译] 进入输入序列。
	// DecryptionPanelHintBreaching: 按序点击矩阵单元，填入目标序列。
	// DecryptionPanelHintDataFlood: 协议通道打开，正在注入数据洪流...
	// DecryptionPanelHintMessage: 解码完成，以下为截获片段。
	// DecryptionPanelBeginBreach: ▷ 启动破译
	// DecryptionPanelClose: ✕ 断开
	// DecryptionPanelStatusLocked: LOCKED
	// DecryptionPanelStatusBreaching: BREACHING
	// DecryptionPanelStatusDataFlood: INJECTING
	// DecryptionPanelStatusMessage: DECODED
	// BreachBuffer: 缓冲区 {0}/{1}
	// BreachTargets: 目标序列
	// BreachTimer: 剩余时间
	// BreachAxisRow: 行约束 ▸ 第{0}行
	// BreachAxisCol: 列约束 ▸ 第{0}列
	// BreachCooldown: 协议重置中 {0:0.0}s
	// BreachAttempt: 尝试 #{0}
	// BreachRestart: ⟳ 重试
}

MessageStrings: {
	// MsgHeader: ── 截获片段 ▸ 来源 0x{0} / {1} ──
	// MsgSrcSystem: SYS
	// MsgSrcSignal: SIG
	// MsgSrcArchive: ARC
	// MsgFragment: FRAGMENT
	// MsgSignature: SIGN   ▸ {0}
	// MsgBody0: 终端已接入。校验密钥匹配度 98.4%。
	// MsgBody1: ...噪声中仍残留未标注的脉冲信号。
	// MsgBody2: 坐标偏移量指向坍缩核心的深层回声。
	// MsgBody3: 该节点被标记为 ██CLASSIFIED██，相关片段已封存。
	// MsgBody4: 下一个协议窗口将由你的行动触发。
	// MsgSkipHint: "[空格/左键] 跳过逐字显示"
	// MsgCloseHint: "[空格/ESC] 断开连接"
	// MsgAccess: 访问权限： Draedon
	// MsgStatus: 状态： 局部解密
	// MsgRec01Title: "[记录-01]"
	// MsgRec01_0: 大尖啸。无法解析波段，像是整个宇宙都在尖叫。
	// MsgRec01_1: 空间曲率永久锁死。折跃引擎彻底报废。强行跃迁的结果只有物质结构的解体。
	// MsgRec01_2: 常规星际航行终结。旧物理统一模型崩溃。
	// MsgRec02Title: "[记录-02]"
	// MsgRec02_0: 七万三千次探测器损毁后，锁定当前虚空坐标。
	// MsgRec02_1: 建立零号基地。铺设配套工业群。
	// MsgRec02_2: 此处的现实壁垒已被拉扯至极限，可以直接目视那片无序的亚空间风暴。
	// MsgRec02_3: 绝佳的观测点。
	// MsgRec03Title: "[记录-03]"
	// MsgRec03_0: 风暴正在渗漏。
	// MsgRec03_1: 物理学退位。绝对的唯心规则开始接管这片工业区。
	// MsgRec03_2: 时间线出现重叠。尸体、过往残影与亚空间能量开始结合。
	// MsgRec03_3: 工业区中开始频繁观察到怪异现象。
	// MsgRec04Title: "[记录-04]"
	// MsgRec04_0: 清理这些灵异对象属于徒劳，它们无法被杀死。留作基地的外部屏障。
	// MsgRec04_1: 若该日志被触发，意味着我已经放弃此地，所有向外界的通道已经关闭。
	// MsgRec04_2: 后来者，自行在那些脏东西的规律里寻找机会。
}

