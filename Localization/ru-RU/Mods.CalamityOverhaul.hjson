# For Language Pack Creators:
# The keys here were previously in Items. Since EcTypeItem has been removed, all localization keys similar to "ItemNameEcType" have been moved here.
# The corresponding format is "ItemNameEcType" → "RItemName" or "ItemNameOverride".
# Apart from the class name change, the DisplayName and Tooltip remain the same as in the previous version.
# So if you need to migrate your language pack to the new version, simply copy and paste the entries here and update the class names accordingly.

Arcanes: {
	Items: {
		ArcaneTransformer: {
			DisplayName: Чародейский преобразователь
			Tooltip: ""
		}
	}
}

Resurrections: {
	ResurrectionDeath: {
		DeathText: "{0} погибает от Возрождения Бездны"
		WarningCombatText: Бездна поглощает вас...
		DeathNoticeText: Вас поглотила Бездна...
		MarkRemainText: Метка Бездны всё ещё опутывает вас...
		RetainValueFormat: Значение Возрождения: {0}%
	}
}

QuickHack: {
	SynapseBurn: {
		DisplayName: Плавление синапсов
		Description: Перегружает нейронные синапсы цели, нанося продолжительный термический урон.
	}

	ShortCircuit: {
		DisplayName: Замыкание
		Description: Выпускает электромагнитный импульс, наносящий мгновенный урон и кратковременно парализующий цель.
	}

	Cyberpsychosis: {
		DisplayName: Киберпсихоз
		Description: Доводит цель до безумия, заставляя атаковать все сущности вокруг.
	}

	SystemReset: {
		DisplayName: Сброс системы
		Description: Принудительно перезагружает систему цели, полностью ее парализуя.
	}

	OpticOverload: {
		DisplayName: Сбой оптики
		Description: Ослепляет цель, лишая ее возможности воспринимать окружение.
	}

	MemoryWipe: {
		DisplayName: Стирание памяти
		Description: Удаляет данные о враждебности цели, сбрасывая список агрессии.
	}

	Contagion: {
		DisplayName: Заражение
		Description: Внедряет самовоспроизводящуюся вредоносную программу, распространяющуюся на ближайшие цели.
	}

	TileDetonate: {
		DisplayName: Подрыв блока
		Description: Разрушает структурную целостность, вызывая локальный взрыв.
	}

	TilePhase: {
		DisplayName: Протокол сдвига
		Description: Искажает физические свойства блока, делая его бестелесным на некоторое время.
	}

	TileMagPull: {
		DisplayName: Магнитное притяжение
		Description: Генерирует магнитное поле, притягивающее к вам ближайшие выпавшие предметы.
	}

	MachineShortCircuit: {
		DisplayName: Замыкание механизмов
		Description: Опустошает запас энергии механической цели, высвобождая электрическую дугу, наносящую урон ближайшим сущностям.
	}

	TurretHijack: {
		DisplayName: Взлом турели
		Description: Взламывает модуль распознавания «свой-чужой», временно заставляя турель атаковать своих.
	}

	FalseMemory: {
		DisplayName: Подмена памяти
		Description: Внедряет ложные воспоминания, заставляя цель ненадолго прекратить преследование или подавляя её инстинкт убийцы.
	}

	SelfDismember: {
		DisplayName: Саморасчленение
		Description: Заставляет паранормальную сущность расчленить саму себя.
	}

	SystemHalt: {
		DisplayName: Сбой системы
		Description: Заставляет цель ненадолго замереть и прекратить любые действия.
	}

	TurretCircuitOverload: {
		DisplayName: Перегрузка цепи
		Description: Подает обратный ток в цепь питания турели, полностью выводя ее из строя на длительное время.
	}

	TurretShortCircuit: {
		DisplayName: Короткое замыкание турели
		Description: Мгновенно сбрасывает энергию турели, вызывая кратковременную остановку, после чего она сразу же возвращается в строй.
	}

	VirusBroadcast: {
		DisplayName: Вирусная трансляция
		Description: Внедряет код червя в сигнальную башню, заставляя ее излучать кибер-электромагнитные импульсы, надолго замыкающие все турели в радиусе действия.
	}
}

