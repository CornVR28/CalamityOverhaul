CybCourseOutroDialogue: {
	// SpeakerName: SHPC
	// Line1: 训练完成。所有接口均已完成校准。
	// Line2: 你已掌握神经直连协议，超梦节点正在脱钩。
	// Line3: 随时可重置训练，或退出超梦。
}

CybCourseCompletePanel: {
	// Title: TRAINING COMPLETE
	// Subtitle: SUPERDREAM PROTOCOL
	// Stat1: "[#] SHPC HUD 校准完毕"
	// Stat2: "[#] 骇客时间校准完毕"
	// Stat3: "[#] 物块扫描接口校准完毕"
	// BtnRetry: RETRY
	// BtnExit: EXIT
	// Footer: "// 选择以继续 — RETRY 重启训练，EXIT 离开超梦"
}

ShepelBloodMoonDialogue: {
	// RoleName: SHPC
	// Line1: 月球引潮力数据异常，夜间敌意生物密度骤升。血月，确认。
	// Line2: 传感器有些嘈杂，不过我一直在。注意脚下，主人。
}

ShepelLowHealthDialogue: {
	// RoleName: SHPC
	// Line1: 主人，生命值不到四分之一了。
	// Line2: 先撤，别逞强。
}

ShepelPlayerRespawnDialogue: {
	// RoleName: SHPC
	// Line1: ……生命体征重新建立了。主人，您刚才断线了一段时间。
	// Line2: 通讯中断的时候我什么都做不了，只能等。下次能不能不要让我等那么久。
	// Line3: 没事了。补充一下生命值，我在。
}

ShepelRainDialogue: {
	// RoleName: SHPC
	// Line1: 降水检测到，这场雨看起来会持续一段时间。
	// Line2: 其实还挺安静的。如果战场允许的话。
}

ShepelSolarEclipseDialogue: {
	// RoleName: SHPC
	// Line1: 日照中断，外来生物信号大规模涌现。日食事件，全线进入高戒备。
	// Line2: 保持移动，我来盯着。
}

ShepelDungeonDialogue: {
	// RoleName: SHPC
	// V0_Line1: 地牢内部，残留能量干扰让扫描信号有点奇怪，一直在处理噪声。
	// V0_Line2: 总有一种被注视的感觉。可能是数据干扰，也可能不是。主人留意。
	// V1_Line1: 地牢的设计者对采光需求明显没什么兴趣。
	// V1_Line2: 走廊宽度、叉路密度，防守设计挺严密的。旧主人还是有想法的。
	// V2_Line1: 书架，这里有书架。很多。
	// V2_Line2: 扫描了一部分，内容大多已经腐蚀。遗憾。
	// VNight_Line1: 地牢加上夜晚，主人选时机真的挺……有品位的。
	// VNight_Line2: 没关系，我的视野不依赖光照。我看着。
}

ShepelFirstNightDialogue: {
	// RoleName: SHPC
	// V0_Line1: 夜幕落下了，夜间的威胁密度比白天高，注意周围。
	// V0_Line2: 我的视野不依赖光照，我看得到。主人怎么样，看得清吗？
	// V1_Line1: 今晚的星象数据比较完整，我在跑例行分析。
	// V1_Line2: 没什么要紧的，只是习惯了有事做。
	// V2_Line1: 晚上安静很多，相对的。
	// V2_Line2: 越安静的时候越要警惕，主人。
	// V3_Line1: 都这么晚了，主人有计划今晚去哪吗。
	// V3_Line2: 问一句，不是催。
}

ShepelJungleDialogue: {
	// RoleName: SHPC
	// V0_Line1: 丛林的生物信号密度是所有地表区域里最高的，我的扫描模块有点跟不上。
	// V0_Line2: 主人在这里打架，背景噪音对我来说真的很嘈杂。不是抱怨，只是说明情况。
	// V1_Line1: 这片区域的菌丝网络走向挺特别的，某些连接模式和我的神经路由有点像。
	// V1_Line2: 纯技术性描述，不是在夸它。
	// V2_Line1: 丛林湿度持续刷新上限，某几个外部传感器不太开心。
	// V2_Line2: 功能正常，只是汇报一下状态。
	// VHard_Line1: 主人，进入硬模式之后丛林的生物信号比之前混乱了不止一个量级。
	// VHard_Line2: 植物会主动攻击这件事，我还是觉得在设计上有些过激。注意周围。
}

ShepelOceanDialogue: {
	// RoleName: SHPC
	// V0_Line1: 海洋区域，水下声学环境和地表差很多。我的某些模块挺喜欢这个频率的。
	// V0_Line2: 如果有机会，想完整扫描一次海底地形。不着急，以后再说。
	// V1_Line1: 海水的温度分层很明显，表层和下方的深渊差了几十度。
	// V1_Line2: 深渊方向的信号比上次又弱了一些，不知道是什么在干扰。
	// V2_Line1: 这片海洋其实挺大的，主人有没有想过往最深处探索一下。
	// V2_Line2: 我不是在催，只是提一嘴。
	// VRain_Line1: 下雨加海洋，海面现在相当嘈杂。
	// VRain_Line2: 往下潜进去反而安静了，挺有意思的对比。
}

ShepelSnowBiomeDialogue: {
	// RoleName: SHPC
	// V0_Line1: 低温区域。理论上低温对电子系统有益，但我并没有感受到性能提升。
	// V0_Line2: 大概是因为主人产生的战斗数据太多了，省出来的算力全被占用了。
	// V1_Line1: 冰晶的光折射数据非常漂亮，这不是评估报告，只是个人看法。
	// V1_Line2: 如果不是还有东西要打，这里其实挺适合待着的。
	// V2_Line1: 雪地的环境噪音是所有地表区域里最低的。
	// V2_Line2: 主人在这里的时候，我的传感器误报率也低了不少。不知道是不是因为这个原因。
}

ShepelUnderworldDialogue: {
	// RoleName: SHPC
	// V0_Line1: 地底深处，热流读数超出了所有预设参数范围。这里的一切比我预想的要极端。
	// V0_Line2: 某些外部传感器在过热警告中，不过我会撑住的。主人也注意别硬撑。
	// V1_Line1: 岩浆作为照明方案，从能源效率角度来说极其浪费。
	// V1_Line2: 不过地狱的居民大概不关心这个。
	// V2_Line1: 这里的建筑痕迹比地表的地牢还要古老，岩浆里泡了这么久也没被侵蚀。
	// V2_Line2: 用的是什么材料，存档一下，以后有机会研究。
	// VBloodMoon_Line1: 血月加地狱，两套警报系统同时运行，有点忙。
	// VBloodMoon_Line2: 不过数据倒是很丰富。主人注意安全。
}
